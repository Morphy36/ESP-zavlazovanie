
substitutions:
  # --- NASTAVENIA ZARIADENIA ---
  dev_name: "vonkajsia-stanica"
  friendly_name: "Vonkajšia Meteostanica"
  
  # Tvoja nadmorská výška (pre prepočet tlaku na hladinu mora)
  altitude_meters: "250" 
  
  # Limity batérie (kalibrácia podľa tvojho deliča)
  batt_multiplier: "2.0"
  batt_min_voltage: "3.0"
  batt_max_voltage: "4.2"

  # Časy spánku (Adaptívny režim)
  sleep_storm_mode_ms: "120000"    # 2 min - Keď prší alebo fúka
  sleep_normal_mode_ms: "600000"   # 10 min - Bežný stav
  sleep_eco_mode_ms: "1800000"     # 30 min - Keď je slabá batéria
  sleep_perf_mode_ms: "300000"     # 5 min - Plná batéria
  sleep_failsafe: "4min"           # Maximálny čas behu

  # Kalibrácia a Hardvér
  rain_calib_dry: "1.033"
  rain_calib_wet: "0.419"
  wind_pullup_res: "10000"
  wifi_ap_timeout: "1min"
  
  # Prahy pre predikciu a adaptívny režim
  wind_storm_threshold: "15.0"     # km/h
  bat_eco_threshold: "20.0"        # %
  bat_storm_min: "30.0"            # %
  bat_perf_threshold: "80.0"       # %
  rain_moisture_threshold: "10.0"  # %

esphome:
  name: ${dev_name}
  friendly_name: ${friendly_name}
  # VYLEPŠENIE: Explicitne nastavíme platformu a projekt
  project:
    name: "custom.meteostanica"
    version: "2.0.0"
  
  # --- BOOT SEQUENCIA ---
  on_boot:
    # VYLEPŠENIE: priority 600 namiesto 1000
    # 1000 beží ešte pred inicializáciou komponentov (WiFi, I2C nie sú ready)
    # 600 beží po inicializácii HW ale pred pripojením WiFi - ideálne
    priority: 600
    then:
      # 1. Spustenie bezpečnostného časovača (Failsafe)
      - script.execute: failsafe_guard
      
      # 2. Zapnutie senzorov
      - logger.log:
          level: INFO
          tag: "boot"
          format: "Zapínam napájanie senzorov..."
      - output.turn_on: rain_sensor_power
      - output.turn_on: i2c_sensor_power
      
      # VYLEPŠENIE: Dlhší čas na ustálenie - BME280 datasheet odporúča min 2ms po power-on,
      # ale cez MOSFET switch s kondenzátorom je 500ms minimum rozumné
      - delay: 2000ms
      
      # 3. Kontrola BME280 (I2C) - VYLEPŠENIE: Presunuté do skriptu pre čistotu
      - script.execute: check_bme280_chip
      
      # 4. Stabilizačné čítania (Flush) 
      # VYLEPŠENIE: 3 flush čítania pre BME280 (prvé 2 sú vždy nepresné po cold boot)
      - component.update: bme280_sensor
      - delay: 150ms
      - component.update: bme280_sensor
      - delay: 150ms
      - component.update: bme280_sensor
      - delay: 100ms
      - component.update: battery_voltage
      
      # VYLEPŠENIE: Aktualizujeme aj LTR390
      - component.update: ltr390_sensor
      
      # 5. Spustenie Wi-Fi logiky
      - script.execute: wifi_connect_logic

  on_shutdown:
    then:
      - logger.log:
          level: INFO
          tag: "shutdown"
          format: "Uspávam LTR390 a vypínam piny."
      - script.execute: uspat_ltr390
      - output.turn_off: rain_sensor_power
      - output.turn_off: i2c_sensor_power

esp32:
  board: esp32dev
  framework:
    type: arduino

# --- WI-FI & API ---
wifi:
  ssid: !secret wifi_ssid
  password: !secret wifi_password
  
  # VYLEPŠENIE: Pridaný manuálny BSSID a kanál pre najrýchlejšie pripojenie
  # Odkomentuj a vyplň po prvom pripojení (zistíš z logov)
  # bssid: "AA:BB:CC:DD:EE:FF"
  # channel: 6
  
  power_save_mode: light
  fast_connect: true
  output_power: 8.5dBm
  
  ap:
    ssid: "Meteo Stanica AP"
    password: "MeteoStanicaAP"
    ap_timeout: ${wifi_ap_timeout}

  on_connect:
    then:
      - logger.log:
          level: INFO
          tag: "wifi"
          format: "Wi-Fi pripojené. RSSI: %d dBm"
          args: ['WiFi.RSSI()']

api:
  id: api_server
  reboot_timeout: 0s
  

  on_client_connected:
    then:
      - logger.log:
          level: INFO
          tag: "api"
          format: "API klient pripojený -> Blokujem Deep Sleep."
      - deep_sleep.prevent: deep_sleep_control
      - script.stop: failsafe_guard

  on_client_disconnected:
    then:
      - logger.log:
          level: INFO
          tag: "api"
          format: "API klient odpojený -> Povoľujem Deep Sleep."
      - deep_sleep.allow: deep_sleep_control
      # VYLEPŠENIE: Malý delay pred spánkom, aby sa stihli odoslať posledné dáta
      - delay: 2s
      - script.execute: check_and_enter_deep_sleep

ota:
  platform: esphome
  password: "esphome"

logger:
  level: WARN
  baud_rate: 0  # VYLEPŠENIE: 0 = vypnutý UART = úspora ~20mA!
  # Pre debug dočasne zmeň na 115200

# VYLEPŠENIE: debug komponent odstránený v produkcii (žerie pamäť a CPU)
# debug:

# web_server a captive_portal sú zbytočné pre batériové zariadenie
# captive_portal:

# --- HARDWARE ---
i2c:
  sda: GPIO22
  scl: GPIO21
  scan: false
  id: busa
  frequency: 100kHz  # POZNÁMKA: BME280 zvláda aj 400kHz, ale 100k je spoľahlivejšie s dlhšími káblami
  timeout: 50ms

# --- GLOBÁLNE PREMENNÉ ---
globals:
  - id: pressure_history
    type: float[6]
    restore_value: true
    initial_value: "{NAN, NAN, NAN, NAN, NAN, NAN}"
  - id: history_index
    type: int
    restore_value: true
    initial_value: "0"
  - id: prev_humidity
    type: float
    restore_value: true
    initial_value: "NAN"
  - id: pressure_threshold
    type: float
    restore_value: true
    initial_value: "-0.3"
  - id: humidity_threshold
    type: float
    restore_value: true
    initial_value: "80.0"
  - id: i2c_restart_attempts
    type: int
    restore_value: false
    initial_value: "0"
  # VYLEPŠENIE: Počítadlo bootov pre diagnostiku
  - id: boot_count
    type: int
    restore_value: true
    initial_value: "0"
  # VYLEPŠENIE: Ukladáme posledný sleep mode pre diagnostiku
  - id: last_sleep_mode
    type: int  # 0=normal, 1=storm, 2=eco, 3=perf
    restore_value: true
    initial_value: "0"
  # VYLEPŠENIE: Akumulátor zrážok (resetuje sa denne v HA, ale toto prežije deep sleep)
  - id: daily_rain_accumulator
    type: float
    restore_value: true
    initial_value: "0.0"

# --- SENZORY (Hardware) ---
sensor:
  # 1. BME280 (Teplota, Tlak, Vlhkosť)
  - platform: bme280_i2c
    address: 0x76
    i2c_id: busa
    id: bme280_sensor
    update_interval: never  # VYLEPŠENIE: Manuálne updaty, nie automatické (šetríme energiu)
    temperature:
      name: "Vonkajšia Teplota"
      id: bme280_temperature
      oversampling: 4x
      # VYLEPŠENIE: Filtre pre elimináciu odchýlok
      filters:
        - offset: 0.0  # Kalibračný offset (nastav po porovnaní s referenciou)
        - lambda: |-
            if (x < -40.0 || x > 60.0) return {};  // Odmietni nezmyselné hodnoty
            return x;
    pressure:
      name: "Absolútny tlak"
      id: bme280_pressure
      oversampling: 4x
      filters:
        - lambda: |-
            if (x < 800.0 || x > 1100.0) return {};  // Odmietni nezmyselné hodnoty
            return x;
      on_value:
        then:
          - lambda: |-
              float h = ${altitude_meters}; 
              float t = id(bme280_temperature).state;
              if (isnan(t)) t = 15.0; // Fallback teplota pre výpočet
              float msl = x * pow(1.0 - (0.0065 * h) / (t + 0.0065 * h + 273.15), -5.257);
              id(msl_pressure).publish_state(msl);
    humidity:
      name: "Vonkajšia Vlhkosť"
      id: bme280_humidity
      oversampling: 4x
      filters:
        - lambda: |-
            if (x < 0.0 || x > 100.0) return {};  // Odmietni nezmyselné hodnoty
            return x;

  # 2. LTR390 (Svetlo, UV)
  - platform: ltr390
    address: 0x53
    i2c_id: busa
    id: ltr390_sensor
    update_interval: never  # VYLEPŠENIE: Manuálne updaty
    # VYLEPŠENIE: Pridané gain a resolution nastavenia
    gain: "X3"
    resolution: 18
    light:
      name: "Intenzita svetla"
      id: ambient_light
    uv:
      name: "UV Index (RAW)"
      id: uv_raw_data
      internal: true

  # 3. Batéria (ADC)
  - platform: adc
    pin: GPIO35
    name: "Napätie batérie"
    id: battery_voltage
    update_interval: never  # VYLEPŠENIE: Manuálne updaty
    attenuation: 12db
    accuracy_decimals: 2
    filters:
      - multiply: ${batt_multiplier}
      # VYLEPŠENIE: Mediánový filter je lepší pre batériu (odfiltruje spiky)
      - median:
          window_size: 5
          send_every: 1
          send_first_at: 1

  # 4. Dažďový senzor (Analógová vlhkosť)
  - platform: adc
    pin: GPIO34
    id: rain_sensor_voltage
    name: "Napätie dažďového senzora"
    entity_category: diagnostic
    update_interval: never  # VYLEPŠENIE: Manuálne
    attenuation: 12db

  - platform: template
    name: "Vlhkosť dažďového senzora"
    id: rain_sensor_percent
    unit_of_measurement: "%"
    icon: "mdi:water-percent"
    lambda: |-
      if (!id(rain_sensor_voltage).has_state()) return NAN;
      float val = id(rain_sensor_voltage).state;
      // Ochrana pred delením nulou a nezmyselnými hodnotami
      float dry = ${rain_calib_dry};
      float wet = ${rain_calib_wet};
      if (abs(dry - wet) < 0.01) return NAN;
      float result = (val - dry) / (wet - dry) * 100.0f;
      return clamp(result, 0.0f, 100.0f);
    update_interval: never

  # 5. Anemometer (Vietor) - HARDWARE PCNT
  - platform: pulse_counter
    pin:
      number: GPIO25
      mode: INPUT_PULLUP
    name: "Rýchlosť vetra (Priemer)"
    id: wind_speed
    unit_of_measurement: "km/h"
    update_interval: 5s
    use_pcnt: true
    # VYLEPŠENIE: Debounce filter pre mechanický anemometer
    internal_filter: 13us
    filters:
      - multiply: 0.04
      # VYLEPŠENIE: Filtrovanie nulového šumu (keď vietor nefúka)
      - lambda: |-
          if (x < 0.5) return 0.0f;
          return x;

  - platform: copy
    source_id: wind_speed
    name: "Rýchlosť vetra (Náraz-Gust)"
    id: wind_gust
    filters:
      - multiply: 0.04
      - max: 
          window_size: 5
          send_every: 1
          send_first_at: 1

  # 6. Zrážkomer (Kýblik) - HARDWARE PCNT
  - platform: pulse_counter
    pin:
      number: GPIO26
      mode: INPUT_PULLUP
    name: "Intenzita zrážok"
    id: rain_fall_rate
    unit_of_measurement: "mm/h"
    update_interval: 60s
    use_pcnt: true
    internal_filter: 13us        # ← OPRAVA: max povolená hodnota pre PCNT
    filters:
      - multiply: 16.764
    total:
      name: "Celkové zrážky"
      id: rain_total
      unit_of_measurement: "mm"
      accuracy_decimals: 2
      filters:
        - multiply: 0.2794
      on_value:
        then:
          - lambda: |-
              id(daily_rain_accumulator) = x;

  # 7. Smer vetra (ADC + Výpočet) 
  - platform: adc
    pin: GPIO33
    id: wind_vane_voltage
    name: "Napätie smeru vetra"
    internal: true
    update_interval: 10s
    attenuation: 12db
    # VYLEPŠENIE: Priemer pre stabilnejšie čítanie
    filters:
      - median:
          window_size: 3
          send_every: 1
          send_first_at: 1

  - platform: template
    name: "Smer vetra (Uhol)"
    id: wind_direction_angle
    unit_of_measurement: "°"
    icon: "mdi:compass-rose"
    lambda: |-
      if (!id(wind_vane_voltage).has_state()) return NAN;
      float v = id(wind_vane_voltage).state;
      
      // VYLEPŠENIE: Lepšia ochrana + kontrola či vietor vôbec fúka
      if (v < 0.05f || !id(wind_speed).has_state() || id(wind_speed).state < 0.5f) return NAN;
      
      float r_vane = ${wind_pullup_res} * ((3.3f / v) - 1.0f);
      
      // VYLEPŠENIE: Zoradená tabuľka podľa odporu pre rýchlejšie vyhľadávanie
      // + tolerancia 15% namiesto absolútneho rozdielu
      struct WindDir { float resistance; float angle; };
      static const WindDir dirs[] = {
        {688, 112.5}, {891, 67.5}, {1000, 90}, {1410, 157.5},
        {2200, 135}, {3140, 202.5}, {3900, 180}, {6570, 22.5},
        {8200, 45}, {14120, 247.5}, {16000, 225}, {21880, 337.5},
        {33000, 0}, {42120, 292.5}, {64900, 315}, {120000, 270}
      };
      
      float min_ratio = 1000.0f;
      float best_angle = NAN;
      
      for (int i = 0; i < 16; i++) {
        // Percentuálny rozdiel je presnejší pre široký rozsah odporov
        float ratio = abs(r_vane - dirs[i].resistance) / dirs[i].resistance;
        if (ratio < min_ratio) { min_ratio = ratio; best_angle = dirs[i].angle; }
      }
      
      // VYLEPŠENIE: Ak je najlepšia zhoda horšia ako 30%, senzor je chybný
      if (min_ratio > 0.30f) {
        ESP_LOGW("wind_dir", "Neznámy odpor vetrnej ruže: %.0f Ohm (najbližšia zhoda: %.0f%%)", r_vane, min_ratio * 100);
        return NAN;
      }
      return best_angle;

  # --- Vypočítané senzory ---
  
  - platform: template
    name: "Tlak (Hladina mora)"
    id: msl_pressure
    unit_of_measurement: "hPa"
    accuracy_decimals: 1
    icon: "mdi:gauge"
    # VYLEPŠENIE: device_class pre správnu integráciu s HA
    device_class: atmospheric_pressure
    state_class: measurement

  - platform: template
    name: "Rosný bod"
    id: dew_point
    unit_of_measurement: "°C"
    icon: "mdi:thermometer-water"
    device_class: temperature
    state_class: measurement
    lambda: |-
      if (!id(bme280_temperature).has_state() || !id(bme280_humidity).has_state()) return NAN;
      float T = id(bme280_temperature).state;
      float RH = id(bme280_humidity).state;
      // VYLEPŠENIE: Ochrana pred log(0)
      if (RH <= 0.0f) return NAN;
      float a = 17.27f; float b = 237.7f;
      float alpha = ((a * T) / (b + T)) + log(RH / 100.0f);
      // VYLEPŠENIE: Ochrana pred delením nulou
      if (abs(a - alpha) < 0.001f) return NAN;
      return (b * alpha) / (a - alpha);

  - platform: template
    name: "Pocitová teplota"
    id: feels_like_temp
    unit_of_measurement: "°C"
    icon: "mdi:thermometer-lines"
    device_class: temperature
    state_class: measurement
    lambda: |-
      if (!id(bme280_temperature).has_state() || !id(bme280_humidity).has_state() || !id(wind_speed).has_state()) return NAN;
      float t = id(bme280_temperature).state;
      float h = id(bme280_humidity).state;
      float v = id(wind_speed).state;
      
      // Wind Chill (Environment Canada formula)
      if (t <= 10.0f && v >= 4.8f) {
        return 13.12f + (0.6215f * t) - (11.37f * pow(v, 0.16f)) + (0.3965f * t * pow(v, 0.16f));
      }
      // Heat Index (Rothfusz regression - NOAA)
      if (t >= 26.0f && h >= 40.0f) {
        float hi = -8.785f + 1.611f*t + 2.339f*h - 0.146f*t*h - 0.013f*t*t - 0.016f*h*h + 0.002f*t*t*h + 0.001f*t*h*h - 0.000004f*t*t*h*h;
        // VYLEPŠENIE: Sanity check
        if (hi < t) hi = t;
        return hi;
      }
      return t;

  - platform: template
    name: "UV Index"
    id: uv_index_calc
    unit_of_measurement: "UVI"
    accuracy_decimals: 1
    icon: "mdi:sun-wireless"
    lambda: |-
      if (!id(uv_raw_data).has_state()) return NAN;
      float raw = id(uv_raw_data).state;
      // VYLEPŠENIE: Ochrana pred záporným UV indexom
      if (raw <= 0.0f) return 0.0f;
      float uvi = raw / 170.0f;
      // VYLEPŠENIE: Cap na reálne hodnoty (max UVI na Zemi je ~15)
      if (uvi > 15.0f) {
        ESP_LOGW("uv", "Nereálny UV index: %.1f (raw: %.0f)", uvi, raw);
        return NAN;
      }
      return uvi;

  - platform: template
    name: "Úroveň batérie"
    id: battery_level
    unit_of_measurement: "%"
    device_class: battery
    state_class: measurement
    lambda: |-
      if (!id(battery_voltage).has_state()) return NAN;
      float v = id(battery_voltage).state;
      // VYLEPŠENIE: Nelineárna krivka vybíjania Li-Ion (presnejšia ako lineárna)
      // Zjednodušená aproximácia reálnej krivky
      if (v >= 4.15f) return 100.0f;
      if (v >= 4.0f)  return 85.0f + (v - 4.0f) * 100.0f;   // 85-100%
      if (v >= 3.75f) return 35.0f + (v - 3.75f) * 200.0f;   // 35-85%
      if (v >= 3.5f)  return 10.0f + (v - 3.5f) * 100.0f;    // 10-35%
      if (v >= 3.3f)  return 2.0f + (v - 3.3f) * 40.0f;      // 2-10%
      if (v >= ${batt_min_voltage}) return 1.0f;
      return 0.0f;

  # Diagnostika
  - platform: internal_temperature
    name: "Teplota CPU"
    entity_category: diagnostic
    update_interval: never

  - platform: uptime
    name: "Čas behu"
    id: uptime_sensor
    update_interval: 1s
    entity_category: diagnostic

  - platform: wifi_signal
    name: "WiFi Signál dBm"
    id: wifi_signal_dbm
    update_interval: never  # VYLEPŠENIE: Manuálne (načítame raz pri boote)
    entity_category: diagnostic

  - platform: copy
    source_id: wifi_signal_dbm
    name: "Kvalita WiFi"
    unit_of_measurement: "%"
    entity_category: diagnostic
    filters:
      - lambda: |-
          if (x <= -100.0f) return 0.0f;
          if (x >= -50.0f) return 100.0f;
          return 2.0f * (x + 100.0f);

  # VYLEPŠENIE: Počítadlo bootov ako diagnostický senzor
  - platform: template
    name: "Počet bootov"
    id: boot_count_sensor
    entity_category: diagnostic
    accuracy_decimals: 0
    lambda: |-
      return (float)id(boot_count);

# --- BINÁRNE SENZORY ---
binary_sensor:
  - platform: status
    name: "Status Stanice"

  - platform: template
    name: "Detekcia dažďa"
    id: rain_detection
    device_class: moisture
    lambda: |-
      // VYLEPŠENIE: Kombinovaná detekcia - analógový senzor ALEBO tipping bucket
      bool analog_rain = false;
      bool bucket_rain = false;
      
      if (id(rain_sensor_percent).has_state()) {
        analog_rain = id(rain_sensor_percent).state > ${rain_moisture_threshold};
      }
      if (id(rain_fall_rate).has_state()) {
        bucket_rain = id(rain_fall_rate).state > 0.0f;
      }
      
      return analog_rain || bucket_rain;
    filters:
      - delayed_on: 3s   # VYLEPŠENIE: Kratší delay pre rýchlejšiu reakciu
      - delayed_off: 10s  # VYLEPŠENIE: Dlhší delayed_off - dážď nekončí okamžite

  - platform: template
    name: "Kritická batéria"
    id: low_battery
    device_class: battery
    lambda: |-
      if (!id(battery_voltage).has_state()) return false;
      return id(battery_voltage).state < (${batt_min_voltage} + 0.1f);

  - platform: template
    name: "Predikcia dažďa (Tlak)"
    id: rain_prediction
    icon: "mdi:weather-rainy"
    lambda: |-
      if (!id(bme280_pressure).has_state() || !id(bme280_humidity).has_state()) return false;

      float cur_p = id(bme280_pressure).state;
      float hum = id(bme280_humidity).state;

      // Zápis do histórie
      id(pressure_history)[id(history_index)] = cur_p;
      id(history_index) = (id(history_index) + 1) % 6;

      int valid = 0; float sum = 0.0f;
      float oldest_valid = NAN;
      for (int i = 0; i < 6; i++) {
        if (!isnan(id(pressure_history)[i]) && id(pressure_history)[i] > 800.0f) { 
          sum += id(pressure_history)[i]; 
          valid++;
          // VYLEPŠENIE: Uložíme najstaršiu platnú hodnotu pre trend
          if (isnan(oldest_valid)) oldest_valid = id(pressure_history)[i];
        }
      }
      
      if (valid < 2) return false; 
      
      float avg = sum / valid;
      float dP = cur_p - avg;
      
      // VYLEPŠENIE: Trend vlhkosti s deadband (zabraňuje oscilácii)
      bool hum_rising = false;
      if (!isnan(id(prev_humidity))) {
        hum_rising = (hum - id(prev_humidity)) > 2.0f;  // Min 2% zmena
      }
      id(prev_humidity) = hum;

      // Logika predpovede
      if (dP < id(pressure_threshold) && cur_p < avg && hum_rising) return true;
      if (cur_p < 1000.0f && hum > id(humidity_threshold)) return true;
      // VYLEPŠENIE: Rýchly pokles tlaku (>2hPa) = takmer istý dážď
      if (dP < -2.0f) return true;
      
      return false;

# --- TEXTOVÉ SENZORY (UI) ---
text_sensor:
  - platform: template
    name: "Odporúčanie oblečenia"
    icon: "mdi:hanger"
    id: clothing_recommendation
    update_interval: never  # VYLEPŠENIE: Manuálne (aktualizujeme pri čítaní)
    lambda: |-
      if (!id(bme280_temperature).has_state()) return std::string("Načítavam...");
      float t = id(bme280_temperature).state;
      bool rain = id(rain_prediction).state || id(rain_detection).state;
      float wind = id(wind_speed).has_state() ? id(wind_speed).state : 0.0f;
      // VYLEPŠENIE: Pridaný vietor do odporúčania
      bool windy = wind > 25.0f;

      if (rain) {
        if (t < 3)  return std::string("🥶 Ľadový dážď! Zimná bunda, dáždnik, pozor na námrazu!");
        if (t < 10) return std::string("🌧️ Prší a je zima. Zimná bunda + dáždnik.");
        if (t < 20) return std::string("🌦️ Prší. Nepremokavá bunda.");
        return std::string("⛈️ Teplý dážď. Ľahká bunda + dáždnik.");
      }
      if (t < -5) return std::string("🧊 Tuhý mráz! Vrstvy, zimná bunda, čiapka, šál, rukavice.");
      if (t < 5)  return std::string("❄️ Mráz! Zimná bunda, čiapka, rukavice.");
      if (t < 15) {
        if (windy) return std::string("💨 Chladno a veterno. Vetrovka + sveter.");
        return std::string("🧥 Chladno. Sveter a bunda.");
      }
      if (t < 22) return std::string("👕 Príjemne. Mikina alebo tričko.");
      if (t < 30) return std::string("☀️ Teplo. Tričko, nezabudni na opaľovací krém!");
      return std::string("🔥 Horúčava! Naľahko, veľa pitia, hľadaj tieň.");

  - platform: template
    name: "Smer vetra (Text)"
    id: wind_dir_text
    update_interval: never  # VYLEPŠENIE: Manuálne
    lambda: |-
      if (!id(wind_direction_angle).has_state()) return std::string("N/A");
      float angle = id(wind_direction_angle).state;
      if (isnan(angle)) return std::string("Bezvetrie");
      const char* dirs[] = {"S", "SSV", "SV", "VSV", "V", "VJV", "JV", "JJV", "J", "JJZ", "JZ", "ZJZ", "Z", "ZSZ", "SZ", "SSZ"};
      int idx = (int)((angle + 11.25f) / 22.5f) % 16;
      return std::string(dirs[idx]);

  # VYLEPŠENIE: Režim spánku ako textový senzor
  - platform: template
    name: "Režim stanice"
    id: station_mode_text
    icon: "mdi:sleep"
    entity_category: diagnostic
    lambda: |-
      switch(id(last_sleep_mode)) {
        case 1: return std::string("⛈️ STORM (2 min)");
        case 2: return std::string("🔋 ECO (30 min)");
        case 3: return std::string("🚀 PERF (5 min)");
        default: return std::string("🔄 Normal (10 min)");
      }
      

# --- OUTPUTS & SWITCHES ---
output:
  - platform: gpio
    pin: GPIO18
    id: rain_sensor_power
  - platform: gpio
    pin: GPIO19
    id: i2c_sensor_power

switch:
  - platform: template
    name: "Manuálne napájanie senzorov"
    optimistic: true
    entity_category: config
    turn_on_action:
      - output.turn_on: rain_sensor_power
      - output.turn_on: i2c_sensor_power
    turn_off_action:
      - output.turn_off: rain_sensor_power
      - output.turn_off: i2c_sensor_power

  - platform: template
    name: "Vynútiť Deep Sleep"
    icon: "mdi:sleep"
    entity_category: config
    turn_on_action:
      - deep_sleep.enter: deep_sleep_control

  - platform: restart
    name: "Reštartovať Stanicu"
    entity_category: config

# VYLEPŠENIE: Konfigurovateľné prahy cez HA
number:
  - platform: template
    name: "Prah poklesu tlaku"
    id: pressure_threshold_config
    unit_of_measurement: "hPa"
    min_value: -5.0
    max_value: 0.0
    step: 0.1
    initial_value: -0.3
    optimistic: true
    entity_category: config
    set_action:
      - lambda: 'id(pressure_threshold) = x;'

  - platform: template
    name: "Prah vlhkosti pre dážď"
    id: humidity_threshold_config
    unit_of_measurement: "%"
    min_value: 60.0
    max_value: 95.0
    step: 1.0
    initial_value: 80.0
    optimistic: true
    entity_category: config
    set_action:
      - lambda: 'id(humidity_threshold) = x;'

deep_sleep:
  id: deep_sleep_control
  # Trvanie sa nastavuje dynamicky v skripte

# --- SKRIPTY (LOGIKA) ---
script:
  # 1. Failsafe
  - id: failsafe_guard
    mode: restart  # VYLEPŠENIE: restart mode - ak sa spustí znova, resetne sa timer
    then:
      - delay: ${sleep_failsafe}
      - logger.log:
          level: ERROR
          tag: "failsafe"
          format: "Čas vypršal! Núdzový spánok."
      - output.turn_off: rain_sensor_power
      - output.turn_off: i2c_sensor_power
      - deep_sleep.enter:
          id: deep_sleep_control
          sleep_duration: 10min

  # 2. Wi-Fi pripojenie
  - id: wifi_connect_logic
    then:
      - wait_until:
          condition: wifi.connected
          timeout: 15s  # VYLEPŠENIE: 15s stačí s fast_connect
      - if:
          condition: wifi.connected
          then:
            - logger.log:
                level: INFO
                tag: "wifi"
                format: "Wi-Fi OK. Začínam odosielanie dát."
            # VYLEPŠENIE: Počkáme na API pripojenie, až potom aktualizujeme
            - wait_until:
                condition:
                  api.connected:
                timeout: 10s
            - if:
                condition: api.connected
                then:
                  # Teraz urobíme finálne čítanie a odošleme
                  - script.execute: read_all_sensors
                  - delay: 3s  # Čas na odoslanie dát do HA
                  - script.execute: check_and_enter_deep_sleep
                else:
                  - logger.log:
                      level: WARN
                      tag: "wifi"
                      format: "API nepripojené. Idem spať."
                  - deep_sleep.enter:
                      id: deep_sleep_control
                      sleep_duration: 5min
          else:
            - logger.log:
                level: WARN
                tag: "wifi"
                format: "Wi-Fi zlyhalo. Idem spať (Offline)."
            - deep_sleep.enter:
                id: deep_sleep_control
                sleep_duration: 5min

  # VYLEPŠENIE: Centralizované čítanie všetkých senzorov
  - id: read_all_sensors
    then:
      - component.update: bme280_sensor
      - component.update: ltr390_sensor
      - component.update: battery_voltage
      - component.update: rain_sensor_voltage
      - component.update: wifi_signal_dbm
      - delay: 200ms
      # Aktualizácia template senzorov
      - component.update: rain_sensor_percent
      - component.update: dew_point
      - component.update: feels_like_temp
      - component.update: uv_index_calc
      - component.update: battery_level
      - component.update: wind_dir_text
      - component.update: clothing_recommendation
      - component.update: station_mode_text
      - lambda: |-
          id(boot_count) += 1;

  # 3. Uspatie LTR390
  - id: uspat_ltr390
    then:
      - lambda: |-
          auto bus = id(busa);
          if (bus) {
            uint8_t cmd[] = {0x00, 0x00};
            auto err = bus->write(0x53, cmd, 2);
            if (err != esphome::i2c::ERROR_OK) {
              ESP_LOGW("ltr390", "Nepodarilo sa uspať LTR390");
            }
          }

  # 4. Reštart senzorov pri chybe
  - id: restart_i2c_sensors
    mode: restart
    then:
      - lambda: 'id(i2c_restart_attempts) += 1;'
      - logger.log:
          level: WARN
          tag: "i2c"
          format: "Reštartujem I2C senzory (pokus %d/3)"
          args: ['id(i2c_restart_attempts)']
      - output.turn_off: i2c_sensor_power
      - delay: 500ms
      - output.turn_on: i2c_sensor_power
      - delay: 1500ms  # VYLEPŠENIE: Dlhší delay po power cycle
      - if:
          condition:
            lambda: 'return id(i2c_restart_attempts) >= 3;'
          then:
            - logger.log:
                level: ERROR
                tag: "i2c"
                format: "I2C senzory sú mŕtve po 3 pokusoch."
          else:
            - component.update: bme280_sensor

  # 5. BME280 chip check
  - id: check_bme280_chip
    then:
      - lambda: |-
          auto bus = id(busa);
          uint8_t chip_id = 0;
          if (bus->write(0x76, nullptr, 0) != esphome::i2c::ERROR_OK) {
            ESP_LOGE("boot", "BME280 nenájdený na 0x76!");
            // VYLEPŠENIE: Skúsime reštart
            id(restart_i2c_sensors).execute();
          } else {
            uint8_t reg = 0xD0;
            if (bus->write(0x76, &reg, 1) == esphome::i2c::ERROR_OK && 
                bus->read(0x76, &chip_id, 1) == esphome::i2c::ERROR_OK) {
              if (chip_id == 0x60) {
                ESP_LOGI("boot", "BME280 OK (Chip ID: 0x60).");
              } else if (chip_id == 0x58) {
                ESP_LOGW("boot", "BMP280 namiesto BME280! Vlhkosť nebude.");
              } else {
                ESP_LOGW("boot", "Neznámy chip na 0x76 (ID: 0x%02X).", chip_id);
              }
            }
          }

  # 6. HLAVNÝ MOZOG: Adaptívny Deep Sleep
  - id: check_and_enter_deep_sleep
    mode: single  # VYLEPŠENIE: single mode - zabráni viacnásobnému spusteniu
    then:
      - if:
          condition:
            and:
              - wifi.connected:
              - lambda: 'return id(bme280_temperature).has_state();'
          then:
            - lambda: |-
                float bat = id(battery_level).has_state() ? id(battery_level).state : 50.0f;
                bool rain = id(rain_detection).state;
                bool rain_pred = id(rain_prediction).state;
                float wind = id(wind_speed).has_state() ? id(wind_speed).state : 0.0f;
                
                uint32_t sleep_ms = ${sleep_normal_mode_ms};
                std::string mode = "Normal";
                int mode_id = 0;

                // VYLEPŠENIE: Jasnejšia prioritná hierarchia s prahmi z substitutions
                // Priorita 1: KRITICKÁ BATÉRIA - vždy najvyššia priorita
                if (bat < ${bat_eco_threshold}) {
                   sleep_ms = ${sleep_eco_mode_ms};
                   mode = "ECO (Low Bat " + to_string((int)bat) + "%)";
                   mode_id = 2;
                }
                // Priorita 2: AKTÍVNE POČASIE (len ak máme dosť batérie)
                else if ((rain || rain_pred || wind > ${wind_storm_threshold}) && bat > ${bat_storm_min}) {
                   sleep_ms = ${sleep_storm_mode_ms};
                   mode = "STORM";
                   mode_id = 1;
                }
                // Priorita 3: PLNÁ BATÉRIA = častejšie merania
                else if (bat > ${bat_perf_threshold}) {
                   sleep_ms = ${sleep_perf_mode_ms};
                   mode = "High Perf";
                   mode_id = 3;
                }
                
                id(last_sleep_mode) = mode_id;

                ESP_LOGI("sleep", "Mode: %s | Sleep: %us | Bat: %.0f%% | Wind: %.1fkm/h | Rain: %s",
                  mode.c_str(), sleep_ms/1000, bat, wind, rain ? "YES" : "NO");
                
                id(deep_sleep_control).set_sleep_duration(sleep_ms);
            
            - deep_sleep.enter: deep_sleep_control
          else:
            # VYLEPŠENIE: Fallback ak nemáme dáta
            - logger.log:
                level: WARN
                tag: "sleep"
                format: "Nemám dáta, spím na 5 min."
            - deep_sleep.enter:
                id: deep_sleep_control
                sleep_duration: 5min

# VYLEPŠENIE: Interval znížený a s podmienkou
interval:
  - interval: 15s
    then:
      - if:
          condition:
            # Len ak nie je pripojený HA klient (servisný mód)
            not:
              api.connected:
          then:
            - script.execute: check_and_enter_deep_sleep
